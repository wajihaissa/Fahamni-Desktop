<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane id="blogResourceRoot"
            fitToWidth="true"
            hbarPolicy="NEVER"
            focusTraversable="false"
            styleClass="blog-scroll"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.BlogController">

    <VBox id="blogResourceContent" spacing="20" styleClass="blog-content">
        <padding><Insets top="8" right="24" bottom="24" left="24"/></padding>

        <HBox id="blogResourceHero" alignment="CENTER_LEFT" spacing="16">
            <styleClass>
                <String fx:value="blog-header"/>
                <String fx:value="front-blog-hero"/>
            </styleClass>
            <VBox spacing="8">
                <Label text="Blog Fahamni" styleClass="blog-hero-title"/>
                <Label text="Articles et ressources educatives de notre communaute"
                       wrapText="true"
                       styleClass="blog-hero-subtitle"/>
            </VBox>
        </HBox>

        <HBox id="blogResourceToolbar" spacing="12" alignment="CENTER_LEFT">
            <styleClass>
                <String fx:value="blog-controls"/>
                <String fx:value="front-blog-toolbar"/>
            </styleClass>
            <Label text="Recherche" styleClass="blog-search-icon"/>
            <TextField fx:id="searchField"
                       promptText="Rechercher un article..."
                       styleClass="search-field"
                       focusTraversable="true"
                       HBox.hgrow="ALWAYS"/>
            <Separator orientation="VERTICAL" style="-fx-opacity: 0.3;"/>
            <Label text="Trier par :" styleClass="blog-sort-label"/>
            <ComboBox fx:id="sortComboBox" focusTraversable="false">
                <styleClass>
                    <String fx:value="filter-combo"/>
                    <String fx:value="blog-sort-combo"/>
                </styleClass>
            </ComboBox>
        </HBox>

        <HBox id="blogCategoryBar" spacing="10" alignment="CENTER_LEFT" styleClass="blog-category-row">
            <Button fx:id="btnTous" text="Tous"
                    focusTraversable="false"
                    onAction="#filterTous">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="active"/>
                </styleClass>
            </Button>
            <Button fx:id="btnMath" text="Mathematiques"
                    focusTraversable="false"
                    onAction="#filterMath">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="math"/>
                </styleClass>
            </Button>
            <Button fx:id="btnScience" text="Sciences"
                    focusTraversable="false"
                    onAction="#filterScience">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="science"/>
                </styleClass>
            </Button>
            <Button fx:id="btnInfo" text="Informatique"
                    focusTraversable="false"
                    onAction="#filterInfo">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="info"/>
                </styleClass>
            </Button>
            <Button fx:id="btnLangue" text="Langues"
                    focusTraversable="false"
                    onAction="#filterLangue">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="languages"/>
                </styleClass>
            </Button>
            <Button fx:id="btnAutre" text="Autres"
                    focusTraversable="false"
                    onAction="#filterAutre">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="neutral"/>
                </styleClass>
            </Button>
            <Button fx:id="btnFavoris" text="&#11088; Favoris"
                    focusTraversable="false"
                    onAction="#filterFavoris">
                <styleClass>
                    <String fx:value="blog-filter-chip"/>
                    <String fx:value="neutral"/>
                </styleClass>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="createArticleBtn" text="+ Creer un article"
                    focusTraversable="false"
                    onAction="#openCreateForm"
                    styleClass="front-blog-create-button"/>
        </HBox>

        <VBox fx:id="blogsContainer" spacing="16"/>

        <HBox fx:id="paginationBar" spacing="8" alignment="CENTER_LEFT" styleClass="front-blog-pagination">
        </HBox>

    </VBox>
</ScrollPane>
