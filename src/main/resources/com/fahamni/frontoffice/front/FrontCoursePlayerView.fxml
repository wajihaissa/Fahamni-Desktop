<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.FrontCoursePlayerController"
            style="-fx-background-color: linear-gradient(to bottom, #f8fafc, #eef2ff);">

    <top>
        <VBox spacing="10.0" style="-fx-padding: 20 24 12 24;">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button text="← Retour aux cours"
                        onAction="#goBackToCourses"
                        style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label fx:id="courseTitleLabel"
                   text="Lecteur de cours"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

            <Label fx:id="courseDescriptionLabel"
                   text="Selectionnez un chapitre et explorez les ressources."
                   wrapText="true"
                   style="-fx-font-size: 14px; -fx-text-fill: #475569;"/>

            <FlowPane fx:id="courseCategoriesContainer" hgap="8.0" vgap="8.0"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-control-inner-background: transparent;">
            <content>
                <VBox fx:id="chaptersContainer" spacing="14.0" style="-fx-padding: 20;"/>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
