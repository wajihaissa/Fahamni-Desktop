<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="dashboard-scroll"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.ProfileSettingsController">
    <VBox spacing="20.0" styleClass="dashboard-content">
        <padding>
            <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
        </padding>

        <HBox spacing="0.0" styleClass="profile-settings-shell">
            <VBox prefWidth="270.0" styleClass="profile-settings-sidebar">
                <VBox spacing="8.0" styleClass="profile-settings-sidebar-header">
                    <Label text="Profile Settings" styleClass="profile-sidebar-title"/>
                    <Label text="Manage your account" styleClass="profile-sidebar-copy"/>
                    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-sidebar-user-card">
                        <Label fx:id="profileAvatarLabel" text="FS" styleClass="profile-avatar-large"/>
                        <VBox spacing="2.0">
                            <Label fx:id="sidebarProfileNameLabel" text="Etudiant Fahamni" styleClass="profile-sidebar-user-name"/>
                            <Label fx:id="sidebarProfileEmailLabel" text="etudiant@fahamni.tn" styleClass="profile-sidebar-user-email"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="10.0" styleClass="profile-nav-list">
                    <Button fx:id="personalInfoNavButton" maxWidth="Infinity" onAction="#showPersonalInfoSection"
                            styleClass="profile-nav-button" text="Personal Info"/>
                    <Button fx:id="accountSettingsNavButton" maxWidth="Infinity" onAction="#showAccountSettingsSection"
                            styleClass="profile-nav-button" text="Account Settings"/>
                    <Button fx:id="certificationsNavButton" maxWidth="Infinity" onAction="#showCertificationsSection"
                            styleClass="profile-nav-button" text="Certifications"/>
                    <Button fx:id="securityNavButton" maxWidth="Infinity" onAction="#showSecuritySection"
                            styleClass="profile-nav-button" text="Security"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="10.0" styleClass="profile-sidebar-footer">
                    <Label text="Settings that affect account status stay managed in the backoffice."
                           wrapText="true" styleClass="section-subtitle"/>
                    <Button maxWidth="Infinity" onAction="#handleDeleteAccount" styleClass="profile-outline-danger-button"
                            text="Delete Account"/>
                </VBox>
            </VBox>

            <VBox spacing="18.0" HBox.hgrow="ALWAYS" styleClass="profile-settings-content">
                <VBox spacing="6.0">
                    <Label fx:id="contentTitleLabel" text="Personal Info" styleClass="profile-content-title"/>
                    <Label fx:id="contentSubtitleLabel"
                           text="Update your personal details and profile information."
                           styleClass="section-subtitle" wrapText="true"/>
                </VBox>

                <Label fx:id="feedbackLabel" managed="false" visible="false" wrapText="true" styleClass="backoffice-feedback"/>

                <StackPane>
                    <VBox fx:id="personalInfoSection" managed="false" visible="false" spacing="18.0" styleClass="profile-section-panel">
                        <VBox spacing="8.0">
                            <Label text="Profile Picture" styleClass="form-label"/>
                            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-upload-row">
                                <Button onAction="#handleChooseProfilePicture" styleClass="profile-inline-button"
                                        text="Choisir un fichier"/>
                                <Label fx:id="profilePictureStatusLabel" text="Aucun fichier choisi" styleClass="section-subtitle"/>
                            </HBox>
                            <Label text="Accepted: JPG, PNG, WEBP. Max size: 5MB." styleClass="profile-inline-note"/>
                        </VBox>

                        <HBox spacing="20.0">
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="First Name" styleClass="form-label"/>
                                <TextField fx:id="firstNameField" promptText="First name" styleClass="form-field"/>
                            </VBox>
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Last Name" styleClass="form-label"/>
                                <TextField fx:id="lastNameField" promptText="Last name" styleClass="form-field"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="8.0">
                            <Label text="Email Address" styleClass="form-label"/>
                            <TextField fx:id="emailField" editable="false" promptText="Email address"
                                       styleClass="form-field profile-readonly-field"/>
                            <Label text="Email cannot be changed from the front office for now." styleClass="profile-inline-note"/>
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Phone Number" styleClass="form-label"/>
                            <TextField fx:id="phoneField" promptText="+216 00 000 000" styleClass="form-field"/>
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Bio / About You" styleClass="form-label"/>
                            <TextArea fx:id="bioArea" prefRowCount="5" promptText="Tell us about yourself, your expertise, and your learning goals..."
                                      styleClass="text-area"/>
                            <Label text="Phone and bio stay ready for later. Avatar upload is now connected with stable file storage."
                                   styleClass="profile-inline-note" wrapText="true"/>
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Role" styleClass="form-label"/>
                            <TextField fx:id="roleField" editable="false" styleClass="form-field profile-readonly-field"/>
                            <Label text="Role is assigned at registration or from the backoffice." styleClass="profile-inline-note"/>
                        </VBox>

                        <HBox spacing="12.0" styleClass="profile-form-actions">
                            <Button onAction="#handleSaveProfile" styleClass="profile-accent-button" text="Save Changes"/>
                            <Button onAction="#handleResetForm" styleClass="profile-soft-button" text="Reset"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="accountSettingsSection" managed="false" visible="false" spacing="18.0" styleClass="profile-section-panel">
                        <HBox spacing="20.0">
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Account Status" styleClass="form-label"/>
                                <TextField fx:id="accountStatusField" editable="false" styleClass="form-field profile-readonly-field"/>
                            </VBox>
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Assigned Role" styleClass="form-label"/>
                                <TextField fx:id="accountRoleField" editable="false" styleClass="form-field profile-readonly-field"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="8.0">
                            <Label text="Validation Status" styleClass="form-label"/>
                            <TextField fx:id="validationStatusField" editable="false" styleClass="form-field profile-readonly-field"/>
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Account Created" styleClass="form-label"/>
                            <TextField fx:id="createdAtField" editable="false" styleClass="form-field profile-readonly-field"/>
                            <Label text="These values are managed by admins in the backoffice only." styleClass="profile-inline-note"/>
                        </VBox>
                    </VBox>

                    <VBox fx:id="certificationsSection" managed="false" visible="false" spacing="18.0" styleClass="profile-section-panel">
                        <VBox spacing="8.0">
                            <Label text="Certifications" styleClass="form-label"/>
                            <TextArea fx:id="certificationsArea" prefRowCount="6"
                                      promptText="e.g., AWS Certified Solutions Architect, IELTS Band 8, Microsoft Azure Fundamentals..."
                                      styleClass="text-area"/>
                            <Label text="Enter each certification separated by commas." styleClass="profile-inline-note"/>
                        </VBox>

                        <HBox spacing="12.0">
                            <Button onAction="#handleSaveCertifications" styleClass="profile-accent-button" text="Save Certifications"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="securitySection" managed="false" visible="false" spacing="18.0" styleClass="profile-section-panel">
                        <VBox spacing="6.0">
                            <Label text="Camera Face ID" styleClass="form-label"/>
                            <Label fx:id="faceEngineStatusLabel" text="Face engine: Connected" styleClass="profile-inline-note"/>
                            <Label fx:id="faceEnrollmentStatusLabel" text="Status: Not enrolled" styleClass="profile-inline-note"/>
                            <Label fx:id="faceEnrolledAtLabel" text="Saved on: Never" styleClass="profile-inline-note"/>
                            <HBox spacing="12.0">
                                <Button onAction="#handleEnrollFaceId" styleClass="profile-accent-button" text="Capture My Face"/>
                                <Button onAction="#handleRemoveFaceId" styleClass="profile-danger-inline-button" text="Remove Face ID"/>
                            </HBox>
                            <Label text="Enrollment opens the webcam, captures a JPEG selfie, then stores only the returned Face++ token."
                                   styleClass="profile-inline-note" wrapText="true"/>
                        </VBox>

                        <VBox spacing="6.0">
                            <Label text="Password" styleClass="form-label"/>
                            <Button onAction="#handleSecurityPlaceholderAction" styleClass="profile-accent-button" text="Change Password"/>
                            <Label text="Use a strong password to protect your account." styleClass="profile-inline-note"/>
                        </VBox>

                        <VBox spacing="6.0">
                            <Label text="Face ID / Passkey" styleClass="form-label"/>
                            <Button onAction="#handleSecurityPlaceholderAction" styleClass="profile-accent-button" text="Enable Face ID Login"/>
                            <Label text="Registers a secure passkey on this device later on." styleClass="profile-inline-note"/>
                        </VBox>

                        <VBox spacing="6.0">
                            <Label text="Authenticator 2FA (TOTP)" styleClass="form-label"/>
                            <Label text="Status: Disabled" styleClass="profile-inline-note"/>
                            <Button onAction="#handleSecurityPlaceholderAction" styleClass="profile-accent-button" text="Start 2FA Setup"/>
                        </VBox>
                    </VBox>
                </StackPane>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
