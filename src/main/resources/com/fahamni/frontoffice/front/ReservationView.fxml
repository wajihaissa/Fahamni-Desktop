                                    <Label text="ðŸ“ Online (Zoom)" styleClass="reservation-info"/>
                                </VBox>
                                <VBox spacing="10.0" alignment="CENTER">
                                    <Label text="50 DT" styleClass="reservation-price"/>
                                    <Label text="Status: Confirmed" styleClass="reservation-status confirmed"/>
                                    <HBox spacing="10.0">
                                        <Button text="Join Session" styleClass="action-button primary"/>
                                        <Button text="Cancel" styleClass="action-button danger"/>
                                    </HBox>
                                </VBox>
                            </HBox>

                            <HBox styleClass="reservation-card" spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
