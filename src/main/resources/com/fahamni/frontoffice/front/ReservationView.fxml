<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" styleClass="reservation-scroll"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.ReservationController">
    <VBox spacing="20.0" styleClass="reservation-content">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <VBox spacing="10.0" styleClass="reservation-header">
            <Label text="My Reservations" styleClass="section-title"/>
            <Label text="Manage your upcoming and past session bookings" styleClass="section-subtitle"/>
        </VBox>

        <TabPane styleClass="reservation-tabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Upcoming">
                    <content>
                        <VBox spacing="15.0" styleClass="tab-content">
                            <HBox styleClass="reservation-card" spacing="15.0">
