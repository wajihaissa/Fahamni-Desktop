                                    <Label text="ðŸ“… Dec 16, 2024 - 2:00 PM" styleClass="reservation-info"/>
                                    <Label text="ðŸ“ Online (Zoom)" styleClass="reservation-info"/>
                                </VBox>
                                <VBox spacing="10.0" alignment="CENTER">
                                    <Label text="75 DT" styleClass="reservation-price"/>
                                    <Label text="Status: Pending" styleClass="reservation-status pending"/>
                                    <HBox spacing="10.0">
                                        <Button text="Pay Now" styleClass="action-button primary"/>
                                        <Button text="Cancel" styleClass="action-button danger"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="History">
                    <content>
                        <VBox spacing="15.0" styleClass="tab-content">
                            <HBox styleClass="reservation-card completed" spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Chemistry - Organic Chemistry" styleClass="reservation-title"/>
                                    <Label text="Tutor: Mohamed Trabelsi" styleClass="reservation-tutor"/>
                                    <Label text="ðŸ“… Nov 20, 2024 - 4:00 PM" styleClass="reservation-info"/>
