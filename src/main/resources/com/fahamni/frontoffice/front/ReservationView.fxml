                                </VBox>
                            </HBox>

                            <HBox styleClass="reservation-card completed" spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="English - Grammar" styleClass="reservation-title"/>
                                    <Label text="Tutor: Leila Khemiri" styleClass="reservation-tutor"/>
