<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.VideoChatController"
            style="-fx-background-color: linear-gradient(to bottom, #0b1220, #121b2f);">

    <top>
        <VBox spacing="10.0" style="-fx-padding: 16;">
            <Label text="Call Lab"
                   style="-fx-text-fill: #f8fafc; -fx-font-size: 26px; -fx-font-weight: bold;"/>
            <Label text="LAN 1-to-1 UDP test environment (video + audio)"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>

            <HBox spacing="12.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(15, 23, 42, 0.9); -fx-background-radius: 14; -fx-padding: 12;">
                <Label text="Connection Setup"
                       style="-fx-text-fill: #e2e8f0; -fx-font-size: 13px; -fx-font-weight: bold;"/>

                <VBox spacing="4.0">
                    <Label text="My Video Port"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                    <TextField fx:id="myPortField" text="5000" promptText="5000"/>
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Target IP"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                    <TextField fx:id="targetIpField" promptText="192.168.1.100" prefWidth="170"/>
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Target Video Port"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                    <TextField fx:id="targetPortField" text="5000" promptText="5000"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Start Call"
                        onAction="#startCall"
                        style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 9 18;"/>
                <Button text="End Call"
                        onAction="#endCall"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 9 18;"/>
                <ToggleButton fx:id="muteMicButton"
                              text="Mute Mic"
                              onAction="#toggleMuteMic"
                              style="-fx-background-color: #1f2937; -fx-text-fill: #e5e7eb; -fx-background-radius: 10; -fx-padding: 9 14;"/>
                <ToggleButton fx:id="cameraOffButton"
                              text="Camera On"
                              onAction="#toggleCamera"
                              style="-fx-background-color: #1f2937; -fx-text-fill: #e5e7eb; -fx-background-radius: 10; -fx-padding: 9 14;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 0 16 16 16;">
            <VBox spacing="8.0"
                  style="-fx-background-color: #0f172a; -fx-background-radius: 16; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.35), 18, 0, 0, 8);">
                <Label text="Remote Camera"
                       style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <ImageView fx:id="remoteCameraView"
                           fitWidth="1100.0"
                           fitHeight="620.0"
                           preserveRatio="true"
                           smooth="true"
                           style="-fx-background-color: black; -fx-background-radius: 14;"/>
            </VBox>

            <VBox spacing="6.0"
                  StackPane.alignment="BOTTOM_RIGHT"
                  style="-fx-background-color: #111827; -fx-background-radius: 12; -fx-padding: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.45), 14, 0, 0, 4);">
                <StackPane.margin>
                    <Insets right="24.0" bottom="24.0"/>
                </StackPane.margin>
                <Label text="Local"
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <ImageView fx:id="localCameraView"
                           fitWidth="260.0"
                           fitHeight="160.0"
                           preserveRatio="true"
                           smooth="true"
                           style="-fx-background-color: black; -fx-background-radius: 10;"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
