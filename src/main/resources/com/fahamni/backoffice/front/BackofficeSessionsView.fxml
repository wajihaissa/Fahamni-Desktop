<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="backoffice-page"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeSessionsController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <VBox spacing="6.0" styleClass="backoffice-header-block">
        <Label text="Consultation des seances" styleClass="backoffice-panel-title"/>
    </VBox>

    <VBox spacing="12.0" styleClass="backoffice-panel" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0">
            <Label text="Recherche et filtres" styleClass="backoffice-section-title"/>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <TextField fx:id="sessionSearchField" promptText="Rechercher par matiere, tuteur, statut ou ID" prefWidth="360.0" styleClass="backoffice-form-input"/>
                <ComboBox fx:id="sessionStatusFilterComboBox" prefWidth="170.0" styleClass="backoffice-form-input"/>
                <DatePicker fx:id="sessionDatePicker" promptText="Date de seance" prefWidth="170.0" styleClass="backoffice-form-input"/>
                <Button onAction="#handleResetSessionFilters" text="Reinitialiser" styleClass="backoffice-secondary-button"/>
            </HBox>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label text="Seances enregistrees" styleClass="backoffice-section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="sessionsCountLabel" text="0 seance affichee" styleClass="backoffice-panel-copy"/>
            <Button onAction="#handleRefreshSessions" text="Actualiser" styleClass="backoffice-secondary-button"/>
            <Button onAction="#handleDeleteSelectedSession" text="Supprimer la seance" styleClass="backoffice-secondary-button"/>
        </HBox>

        <TableView fx:id="sessionsTable" VBox.vgrow="ALWAYS" styleClass="backoffice-table">
            <columns>
                <TableColumn fx:id="sessionIdColumn" prefWidth="60.0" text="ID"/>
                <TableColumn fx:id="subjectColumn" prefWidth="220.0" text="Matiere"/>
                <TableColumn fx:id="tutorColumn" prefWidth="190.0" text="Tuteur"/>
                <TableColumn fx:id="scheduleColumn" prefWidth="180.0" text="Date"/>
                <TableColumn fx:id="durationColumn" prefWidth="90.0" text="Duree"/>
                <TableColumn fx:id="capacityColumn" prefWidth="90.0" text="Places"/>
                <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Statut"/>
            </columns>
        </TableView>

        <Label fx:id="feedbackLabel" managed="false" visible="false" wrapText="true" styleClass="backoffice-feedback"/>
    </VBox>
</VBox>

