<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeCategoryController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="90.0" text="ID"/>
            <TableColumn fx:id="nameColumn" prefWidth="220.0" text="Name"/>
            <TableColumn fx:id="slugColumn" prefWidth="280.0" text="Slug"/>
        </columns>
    </TableView>

    <HBox spacing="10.0">
        <TextField fx:id="nameField" promptText="Category Name" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="slugField" promptText="Slug" HBox.hgrow="ALWAYS"/>
        <Button fx:id="addButton" text="Add" onAction="#handleAdd"/>
        <Button fx:id="updateButton" text="Update" onAction="#handleUpdate"/>
        <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete"/>
    </HBox>
</VBox>
