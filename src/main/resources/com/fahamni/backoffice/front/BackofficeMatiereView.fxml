<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeMatiereController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <TableView fx:id="matiereTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="70.0" text="ID"/>
            <TableColumn fx:id="titreColumn" prefWidth="170.0" text="Titre"/>
            <TableColumn fx:id="descriptionColumn" prefWidth="250.0" text="Description"/>
            <TableColumn fx:id="structureColumn" prefWidth="250.0" text="Structure"/>
            <TableColumn fx:id="createdAtColumn" prefWidth="180.0" text="Created At"/>
        </columns>
    </TableView>

    <VBox spacing="10.0">
        <TextField fx:id="titreField" promptText="Titre"/>
        <TextArea fx:id="descriptionArea" promptText="Description" prefRowCount="3"/>
        <TextArea fx:id="structureArea" promptText="Structure (JSON)" prefRowCount="4"/>
        <TextField fx:id="createdAtField" promptText="Created At (yyyy-MM-dd HH:mm:ss)"/>
        <TextField fx:id="coverImageField" promptText="Cover Image Path"/>

        <HBox spacing="10.0">
            <Button fx:id="ajouterButton" text="Ajouter" onAction="#addMatiere"/>
            <Button fx:id="modifierButton" text="Modifier" onAction="#updateMatiere"/>
            <Button fx:id="supprimerButton" text="Supprimer" onAction="#deleteMatiere"/>
            <Button fx:id="viderButton" text="Vider" onAction="#clearForm"/>
        </HBox>
    </VBox>
</VBox>
