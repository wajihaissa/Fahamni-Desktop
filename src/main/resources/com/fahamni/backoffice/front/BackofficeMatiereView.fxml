<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeMatiereController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <!-- LIST VIEW -->
    <VBox fx:id="listView" VBox.vgrow="ALWAYS" spacing="10.0">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Gestion des mati&#232;res" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Ajouter une Mati&#232;re"
                    onAction="#handleCreateNew"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button fx:id="gererCategoriesButton"
                    text="Cat&#233;gories"
                    onAction="#openCategories"
                    style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="cardsContainer" hgap="20.0" vgap="20.0" style="-fx-padding: 10;" />
            </content>
        </ScrollPane>
    </VBox>

    <!-- EDITOR VIEW -->
    <VBox fx:id="editorView" VBox.vgrow="ALWAYS" spacing="20.0" visible="false" managed="false">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button text="&#x2190; Retour" onAction="#showList" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Label text="&#201;diter Mati&#232;re" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>

        <VBox spacing="10.0">
            <HBox spacing="20.0">
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <Label text="Titre de la mati&#232;re" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="titreField" promptText="Titre"/>

                    <Label text="Description" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="descriptionArea" promptText="Description" prefRowCount="3" wrapText="true"/>

                    <Label text="Chemin de l'image de couverture" style="-fx-font-weight: bold;"/>
                    <HBox spacing="10.0">
                        <Button fx:id="chooseImageButton"
                                text="Choisir une image"
                                onAction="#chooseImage"
                                style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        <Label fx:id="imagePathLabel" text="Aucune image s&#233;lectionn&#233;e"/>
                    </HBox>

                    <VBox spacing="10.0">
                        <Label text="Cat&#233;gories (Tags)" style="-fx-font-weight: bold;"/>
                        <FlowPane fx:id="categoryTagsContainer" hgap="10.0" vgap="10.0" style="-fx-padding: 10; -fx-background-color: #f3f4f6; -fx-background-radius: 5;"/>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <ComboBox fx:id="existingCategoriesCombo" promptText="Choisir une cat&#233;gorie..."/>
                            <Button text="Ajouter" onAction="#addExistingCategory" style="-fx-background-color: #0f766e; -fx-text-fill: white;"/>
                            <Region prefWidth="20.0"/>
                            <TextField fx:id="newCategoryField" promptText="Nouvelle cat&#233;gorie..."/>
                            <Button text="Cr&#233;er &amp; Ajouter" onAction="#createNewCategory" style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Contenu du Cours (Chapitres)" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="+ Ajouter un Chapitre" onAction="#addChapterUI" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </HBox>
                        <ScrollPane fitToWidth="true" prefHeight="300.0" style="-fx-background-color: transparent; -fx-border-color: #e5e7eb; -fx-border-radius: 5;">
                            <VBox fx:id="courseBuilderContainer" spacing="15.0" style="-fx-padding: 10; -fx-background-color: #f9fafb;"/>
                        </ScrollPane>
                    </VBox>
                </VBox>
            </HBox>

            <HBox alignment="CENTER" spacing="10.0">
                <Button fx:id="ajouterButton"
                        text="Ajouter"
                        onAction="#addMatiere"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                <Button fx:id="modifierButton"
                        text="Modifier"
                        onAction="#updateMatiere"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                <Button fx:id="supprimerButton"
                        text="Supprimer"
                        onAction="#deleteMatiere"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                <Button fx:id="viderButton"
                        text="Vider"
                        onAction="#clearForm"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>
