<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="backoffice-scroll"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.BackofficeArticlesController">

    <VBox spacing="18" styleClass="backoffice-page">
        <padding><Insets top="24" right="28" bottom="28" left="28"/></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: linear-gradient(to right,#3a7bd5,#00d2ff);
                     -fx-padding: 16 22; -fx-background-radius: 14;">
            <VBox spacing="3">
                <Label text="Gestion des Articles"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Supervisez les articles soumis par les tuteurs — approuvez ou supprimez."
                       style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.85);"/>
            </VBox>
        </HBox>

        <!-- Notification banner -->
        <HBox fx:id="notifBanner" spacing="10" alignment="CENTER_LEFT" managed="false" visible="false"
              style="-fx-background-color: #fff8e1; -fx-padding: 12 16;
                     -fx-background-radius: 10;
                     -fx-border-color: #f59e0b; -fx-border-radius: 10; -fx-border-width: 1.5;">
            <Label text="🔔" style="-fx-font-size: 16;"/>
            <Label fx:id="notifLabel" text="" wrapText="true"
                   style="-fx-text-fill: #92400e; -fx-font-size: 12; -fx-font-weight: bold;"
                   HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Stat cards -->
        <HBox spacing="14">
            <!-- En attente -->
            <VBox spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14;
                         -fx-padding: 18 20; -fx-border-color: #fed7aa; -fx-border-radius: 14;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="⏳" style="-fx-font-size: 20;"/>
                    <Label text="En attente"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #92400e;"/>
                </HBox>
                <Label fx:id="pendingCountLabel" text="0"
                       style="-fx-font-size: 38; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                <Label text="Articles soumis, pas encore approuves."
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
            </VBox>
            <!-- Approuves -->
            <VBox spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14;
                         -fx-padding: 18 20; -fx-border-color: #bbf7d0; -fx-border-radius: 14;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="✅" style="-fx-font-size: 20;"/>
                    <Label text="Approuves"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #065f46;"/>
                </HBox>
                <Label fx:id="approvedCountLabel" text="0"
                       style="-fx-font-size: 38; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                <Label text="Articles visibles sur la plateforme."
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
            </VBox>
            <!-- Supprimes -->
            <VBox spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14;
                         -fx-padding: 18 20; -fx-border-color: #fecaca; -fx-border-radius: 14;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🗑" style="-fx-font-size: 20;"/>
                    <Label text="Supprimes"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>
                </HBox>
                <Label fx:id="deletedCountLabel" text="0"
                       style="-fx-font-size: 38; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                <Label text="Articles rejetes par l'administrateur."
                       style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
            </VBox>
        </HBox>

        <!-- Filtres + Actualiser -->
        <HBox spacing="8" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-padding: 10 14;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,2);">
            <Button fx:id="btnTous" text="Tous" focusTraversable="false" onAction="#filterTous"
                    style="-fx-background-color: #3a7bd5; -fx-text-fill: white;
                           -fx-background-radius: 20; -fx-padding: 7 20;
                           -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 12;"/>
            <Button text="⏳  En attente" focusTraversable="false" onAction="#filterPending"
                    style="-fx-background-color: #fff8e1; -fx-text-fill: #92400e;
                           -fx-background-radius: 20; -fx-padding: 7 16; -fx-cursor: hand;
                           -fx-font-size: 12; -fx-border-color: #f59e0b; -fx-border-radius: 20;"/>
            <Button text="✅  Approuves" focusTraversable="false" onAction="#filterApproved"
                    style="-fx-background-color: #ecfdf5; -fx-text-fill: #065f46;
                           -fx-background-radius: 20; -fx-padding: 7 16; -fx-cursor: hand;
                           -fx-font-size: 12; -fx-border-color: #10b981; -fx-border-radius: 20;"/>
            <Button text="🗑  Supprimes" focusTraversable="false" onAction="#filterDeleted"
                    style="-fx-background-color: #fff1f2; -fx-text-fill: #991b1b;
                           -fx-background-radius: 20; -fx-padding: 7 16; -fx-cursor: hand;
                           -fx-font-size: 12; -fx-border-color: #ef4444; -fx-border-radius: 20;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Recherche par auteur -->
            <HBox spacing="6" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8fafc; -fx-background-radius: 20;
                         -fx-border-color: #cbd5e1; -fx-border-radius: 20; -fx-padding: 5 12;">
                <Label text="👤" style="-fx-font-size: 13; -fx-text-fill: #94a3b8;"/>
                <TextField fx:id="authorSearchField"
                           promptText="Filtrer par auteur..."
                           focusTraversable="true"
                           style="-fx-background-color: transparent; -fx-border-width: 0;
                                  -fx-font-size: 12; -fx-text-fill: #1e293b; -fx-pref-width: 160;"/>
            </HBox>
            <Button text="↺  Actualiser" focusTraversable="false" onAction="#handleRefresh"
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                           -fx-background-radius: 20; -fx-padding: 7 18; -fx-cursor: hand;
                           -fx-font-size: 12; -fx-border-color: #cbd5e1; -fx-border-radius: 20;"/>
        </HBox>

        <!-- Table articles -->
        <VBox spacing="10"
              style="-fx-background-color: white; -fx-background-radius: 14;
                     -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">

            <!-- Barre titre + actions groupées -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Liste des articles"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Barre sélection multiple (masquée par défaut) -->
                <HBox fx:id="bulkBar" spacing="8" alignment="CENTER" managed="false" visible="false">
                    <Label fx:id="selectionCountLabel" text="0 sélectionné(s)"
                           style="-fx-font-size: 12; -fx-text-fill: #475569; -fx-font-weight: bold;"/>
                    <Button fx:id="btnBulkApprove" text="✔  Approuver la sélection"
                            focusTraversable="false" onAction="#handleBulkApprove"
                            style="-fx-background-color: #10b981; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-padding: 6 14;
                                   -fx-cursor: hand; -fx-font-size: 11; -fx-font-weight: bold;"/>
                    <Button fx:id="btnBulkDelete" text="✕  Supprimer la sélection"
                            focusTraversable="false" onAction="#handleBulkDelete"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-padding: 6 14;
                                   -fx-cursor: hand; -fx-font-size: 11; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>

            <TableView fx:id="articlesTable" VBox.vgrow="ALWAYS" prefHeight="420"
                       style="-fx-background-color: transparent; -fx-border-color: #e2e8f0;
                              -fx-border-radius: 10; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="colSelect"    minWidth="44" maxWidth="44" text=""/>
                    <TableColumn fx:id="colTitre"     minWidth="160" text="Titre"/>
                    <TableColumn fx:id="colAuteur"    minWidth="100" text="Auteur"/>
                    <TableColumn fx:id="colCategorie" minWidth="100" text="Categorie"/>
                    <TableColumn fx:id="colDate"      minWidth="85"  text="Date"/>
                    <TableColumn fx:id="colStatut"    minWidth="95"  text="Statut"/>
                    <TableColumn fx:id="colActions"   minWidth="220" text="Actions"/>
                </columns>
                <placeholder>
                    <Label text="Aucun article dans cette categorie."
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-padding: 30;"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- Feedback -->
        <Label fx:id="feedbackLabel" text="" wrapText="true" managed="false" visible="false"
               style="-fx-font-size: 13; -fx-padding: 10 16; -fx-background-radius: 8;"/>

    </VBox>
</ScrollPane>
