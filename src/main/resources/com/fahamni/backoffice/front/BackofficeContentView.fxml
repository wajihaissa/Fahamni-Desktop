<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="backoffice-page"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeContentController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <VBox spacing="6.0" styleClass="backoffice-header-block">
        <Label text="Gestion du contenu" styleClass="backoffice-panel-title"/>
        <Label text="Supervisez les articles et les ressources publiees sur la plateforme." styleClass="backoffice-panel-copy"/>
    </VBox>

    <HBox spacing="18.0">
        <VBox spacing="12.0" styleClass="backoffice-panel" HBox.hgrow="ALWAYS">
            <Label text="Bibliotheque editoriale" styleClass="backoffice-section-title"/>
            <TableView fx:id="contentTable" VBox.vgrow="ALWAYS" styleClass="backoffice-table">
                <columns>
                    <TableColumn fx:id="titleColumn" prefWidth="240.0" text="Titre"/>
                    <TableColumn fx:id="categoryColumn" prefWidth="150.0" text="Categorie"/>
                    <TableColumn fx:id="authorColumn" prefWidth="150.0" text="Auteur"/>
                    <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Statut"/>
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="12.0" styleClass="backoffice-panel backoffice-form-panel" prefWidth="320.0" minWidth="320.0">
            <Label text="Edition contenu" styleClass="backoffice-section-title"/>

            <VBox spacing="6.0">
                <Label text="Titre" styleClass="backoffice-form-label"/>
                <TextField fx:id="titleField" promptText="Titre de l'article" styleClass="backoffice-form-input"/>
            </VBox>

            <VBox spacing="6.0">
                <Label text="Categorie" styleClass="backoffice-form-label"/>
                <ComboBox fx:id="categoryComboBox" styleClass="backoffice-form-input"/>
            </VBox>

            <VBox spacing="6.0">
                <Label text="Auteur" styleClass="backoffice-form-label"/>
                <TextField fx:id="authorField" promptText="Auteur" styleClass="backoffice-form-input"/>
            </VBox>

            <VBox spacing="6.0">
                <Label text="Statut" styleClass="backoffice-form-label"/>
                <ComboBox fx:id="statusComboBox" styleClass="backoffice-form-input"/>
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleCreateDraft" text="Ajouter un brouillon" styleClass="backoffice-primary-button"/>
            <Button maxWidth="Infinity" onAction="#handlePublishContent" text="Mettre a jour la selection" styleClass="backoffice-secondary-button"/>
            <Button maxWidth="Infinity" onAction="#handleResetContent" text="Reinitialiser le formulaire" styleClass="backoffice-secondary-button"/>

            <Label fx:id="feedbackLabel" managed="false" visible="false" wrapText="true" styleClass="backoffice-feedback"/>
        </VBox>
    </HBox>
</VBox>

