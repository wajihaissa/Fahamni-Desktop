<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="backoffice-page"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeReservationsController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <VBox spacing="6.0" styleClass="backoffice-header-block">
        <Label text="Consultation des reservations" styleClass="backoffice-panel-title"/>
        <Label text="Consultez les reservations enregistrees dans la base. Les traitements restent reserves aux espaces tuteur et etudiant." styleClass="backoffice-panel-copy"/>
    </VBox>

    <VBox spacing="12.0" styleClass="backoffice-panel" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0">
            <Label text="Filtres de consultation" styleClass="backoffice-section-title"/>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <TextField fx:id="searchField" promptText="Rechercher par etudiant, seance, statut ou ID" prefWidth="360.0" styleClass="backoffice-form-input"/>
                <ComboBox fx:id="statusFilterComboBox" prefWidth="170.0" styleClass="backoffice-form-input"/>
                <DatePicker fx:id="reservationDatePicker" promptText="Date de demande" prefWidth="170.0" styleClass="backoffice-form-input"/>
                <Button onAction="#handleResetReservationFilters" text="Reinitialiser" styleClass="backoffice-secondary-button"/>
            </HBox>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label text="Liste des demandes" styleClass="backoffice-section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="resultsCountLabel" text="0 reservation trouvee" styleClass="backoffice-panel-copy"/>
            <Button onAction="#handleRefreshReservations" text="Actualiser" styleClass="backoffice-secondary-button"/>
        </HBox>

        <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS" styleClass="backoffice-table">
            <columns>
                <TableColumn fx:id="reservationIdColumn" prefWidth="70.0" text="ID"/>
                <TableColumn fx:id="studentColumn" prefWidth="220.0" text="Etudiant"/>
                <TableColumn fx:id="sessionColumn" prefWidth="320.0" text="Seance"/>
                <TableColumn fx:id="requestDateColumn" prefWidth="180.0" text="Date de demande"/>
                <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Statut"/>
            </columns>
        </TableView>
    </VBox>
</VBox>

