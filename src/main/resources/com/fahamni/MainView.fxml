<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:id="rootPane" prefHeight="860.0" prefWidth="1440.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.MainController">
    <styleClass>
        <String fx:value="main-root"/>
        <String fx:value="front-navbar-shell-root"/>
    </styleClass>

    <center>
        <VBox spacing="14.0" styleClass="front-navbar-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18" right="16" bottom="18" left="16"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="front-navbar-topbar">
                <padding>
                    <Insets top="12" right="18" bottom="12" left="18"/>
                </padding>

                <VBox spacing="4.0" styleClass="front-navbar-brand">
                    <Label text="FAHAMNI" styleClass="front-navbar-brand-title"/>
                    <Label text="Apprendre avec clarte, progresser avec confiance." wrapText="true"
                           styleClass="front-navbar-brand-slogan"/>
                    <Label fx:id="pageTitle" managed="false" text="Accueil" visible="false"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="front-navbar-actions">
                    <HBox alignment="CENTER" spacing="10.0" styleClass="front-navbar-utility-inline">
                        <StackPane styleClass="front-alert-button-wrap">
                            <Button fx:id="alertButton" onAction="#toggleAlertsPopup" styleClass="front-navbar-icon-button">
                                <graphic>
                                    <StackPane styleClass="front-alert-icon-shell">
                                        <SVGPath content="M10 21c1.1 0 2-.9 2-2H8c0 1.1.9 2 2 2zm6-5v-5c0-3.07-1.63-5.64-4.5-6.32V4a1.5 1.5 0 0 0-3 0v.68C5.63 5.36 4 7.92 4 11v5l-2 2v1h16v-1l-2-2z"
                                                 styleClass="front-alert-icon"/>
                                    </StackPane>
                                </graphic>
                            </Button>
                            <Label fx:id="alertNotifBadge" text=""
                                   StackPane.alignment="TOP_RIGHT"
                                   managed="false" visible="false">
                                <styleClass>
                                    <String fx:value="front-badge"/>
                                    <String fx:value="front-alert-badge"/>
                                </styleClass>
                                <StackPane.margin><Insets top="-7" right="-7"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <Button fx:id="themeToggleButton" onAction="#toggleTheme">
                            <styleClass>
                                <String fx:value="front-navbar-icon-button"/>
                                <String fx:value="front-theme-toggle-button"/>
                            </styleClass>
                            <graphic>
                                <StackPane styleClass="front-theme-icon-shell">
                                    <SVGPath fx:id="themeToggleIcon"
                                             content="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c3.87 0 7.18-2.45 8.44-5.88-.65.28-1.36.43-2.12.43-2.97 0-5.38-2.41-5.38-5.38 0-2.7 1.99-4.94 4.58-5.33A8.96 8.96 0 0 0 12 3z"
                                             styleClass="front-theme-icon"/>
                                </StackPane>
                            </graphic>
                        </Button>

                        <Button fx:id="accountButton" text="Compte" onAction="#toggleAccountMenu" styleClass="front-navbar-ghost-button"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="front-navbar-profile">
                        <Label fx:id="profileAvatarLabel" text="FS" styleClass="profile-avatar"/>
                        <VBox spacing="2.0" styleClass="front-navbar-profile-copy">
                            <Label fx:id="profileNameLabel" text="Etudiant Fahamni" styleClass="profile-name"/>
                            <Label fx:id="profileRoleLabel" text="Espace Etudiant" styleClass="profile-role"/>
                        </VBox>
                    </HBox>
                </HBox>
            </HBox>

            <StackPane styleClass="front-navbar-links-row">
                <padding>
                    <Insets top="0" right="18" bottom="0" left="18"/>
                </padding>

                <FlowPane alignment="CENTER" hgap="18.0" prefWrapLength="1040.0" styleClass="front-navbar-links-center" vgap="8.0" StackPane.alignment="CENTER">
                    <Button fx:id="dashboardButton" text="Accueil" onAction="#showDashboard" styleClass="front-navbar-link"/>
                    <Button fx:id="reservationsButton" text="Trouver un tuteur" onAction="#showReservations" styleClass="front-navbar-link"/>
                    <Button fx:id="seancesButton" text="Calendrier" onAction="#showSeances" styleClass="front-navbar-link"/>
                    <Button fx:id="sallesEquipementsButton" text="Salles &amp; Materiel" onAction="#showSallesEquipements" styleClass="front-navbar-link"/>
                    <Button fx:id="plannerButton" text="Planner" onAction="#showPlanner" styleClass="front-navbar-link"/>
                    <Button fx:id="coursButton" text="Cours" onAction="#showCours" styleClass="front-navbar-link"/>
                    <Button fx:id="callLabButton" text="Call Lab" onAction="#showCallLab" styleClass="front-navbar-link"/>
                    <Button fx:id="quizButton" text="Quiz" onAction="#showQuiz" styleClass="front-navbar-link"/>
                    <Button fx:id="blogButton" text="Blog" onAction="#showBlog" styleClass="front-navbar-link"/>
                    <Button fx:id="aboutButton" text="A Propos" onAction="#showAbout" styleClass="front-navbar-link"/>
                </FlowPane>

                <Button text="Logout" onAction="#handleLogout" styleClass="front-navbar-logout" StackPane.alignment="CENTER_RIGHT"/>
            </StackPane>

            <AnchorPane VBox.vgrow="ALWAYS">
                <styleClass>
                    <String fx:value="content-pane"/>
                    <String fx:value="front-content-surface"/>
                </styleClass>
                <children>
                    <AnchorPane fx:id="contentPane"
                                AnchorPane.bottomAnchor="0.0"
                                AnchorPane.leftAnchor="0.0"
                                AnchorPane.rightAnchor="0.0"
                                AnchorPane.topAnchor="0.0"/>
                    <Region fx:id="globalAiScrim"
                            managed="false"
                            mouseTransparent="true"
                            style="-fx-background-color: rgba(15, 23, 42, 0.16);"
                            visible="false"
                            AnchorPane.bottomAnchor="0.0"
                            AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="0.0"
                            AnchorPane.topAnchor="0.0"/>
                    <VBox fx:id="globalAiPanel"
                          managed="false"
                          maxWidth="400.0"
                          minWidth="400.0"
                          prefWidth="400.0"
                          style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.16), 18, 0, -4, 0);"
                          visible="false"
                          AnchorPane.bottomAnchor="0.0"
                          AnchorPane.rightAnchor="0.0"
                          AnchorPane.topAnchor="0.0">
                        <children>
                            <AnchorPane fx:id="globalAiContent" VBox.vgrow="ALWAYS"/>
                        </children>
                    </VBox>
                    <Button fx:id="globalAiFab"
                            onAction="#toggleGlobalAi"
                            style="-fx-background-color: linear-gradient(to bottom, #0f766e, #0d9488); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 999px; -fx-padding: 12 20;"
                            text="Ask Fahamni"
                            AnchorPane.bottomAnchor="24.0"
                            AnchorPane.rightAnchor="24.0"/>
                </children>
            </AnchorPane>
        </VBox>
    </center>
</BorderPane>
