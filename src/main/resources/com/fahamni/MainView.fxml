<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" styleClass="main-root front-navbar-shell-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.MainController">
    <top>
        <VBox spacing="10.0" styleClass="front-navbar-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12" right="20" bottom="0" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="front-navbar-topbar">
                <padding>
                    <Insets top="12" right="18" bottom="12" left="18"/>
                </padding>

                <VBox spacing="4.0" styleClass="front-navbar-brand">
                    <Label text="FAHAMNI" styleClass="front-navbar-brand-title"/>
                    <Label text="Apprendre avec clarte, progresser avec confiance." styleClass="front-navbar-brand-slogan" wrapText="true"/>
                    <Label fx:id="pageTitle" managed="false" text="Accueil" visible="false"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="10.0" alignment="CENTER_RIGHT" styleClass="front-navbar-actions">
                    <HBox spacing="10.0" alignment="CENTER" styleClass="front-navbar-utility-inline">
                        <AnchorPane styleClass="front-alert-button-wrap">
                            <children>
                                <Button fx:id="alertButton" text="&#128276;" styleClass="front-navbar-icon-button" onAction="#toggleAlertsPopup"
                                        AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
                                <Label fx:id="alertNotifBadge" text=""
                                       managed="false" visible="false"
                                       AnchorPane.rightAnchor="-7.0" AnchorPane.topAnchor="-7.0">
                                    <styleClass>
                                        <String fx:value="front-badge"/>
                                        <String fx:value="front-alert-badge"/>
                                    </styleClass>
                                </Label>
                            </children>
                        </AnchorPane>

                        <Button fx:id="accountButton" text="Compte" styleClass="front-navbar-ghost-button" onAction="#toggleAccountMenu"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="front-navbar-profile">
                        <Label fx:id="profileAvatarLabel" text="FS" styleClass="profile-avatar"/>
                        <VBox spacing="2.0" styleClass="front-navbar-profile-copy">
                            <Label fx:id="profileNameLabel" text="Etudiant Fahamni" styleClass="profile-name"/>
                            <Label fx:id="profileRoleLabel" text="Espace Etudiant" styleClass="profile-role"/>
                        </VBox>
                    </HBox>
                </HBox>
            </HBox>

            <AnchorPane styleClass="front-navbar-links-row">
                <padding>
                    <Insets top="0" right="18" bottom="0" left="18"/>
                </padding>

                <children>
                    <HBox alignment="CENTER" spacing="12.0" styleClass="front-navbar-links-center"
                          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                        <Button fx:id="dashboardButton" text="Accueil" styleClass="front-navbar-link" onAction="#showDashboard"/>
                        <Button fx:id="reservationsButton" text="Trouver un tuteur" styleClass="front-navbar-link" onAction="#showReservations"/>
                        <Button fx:id="seancesButton" text="Calendrier" styleClass="front-navbar-link" onAction="#showSeances"/>
                        <Button fx:id="sallesEquipementsButton" text="Salles &amp; Materiel" styleClass="front-navbar-link" onAction="#showSallesEquipements"/>
                        <Button fx:id="plannerButton" text="Planner" styleClass="front-navbar-link" onAction="#showPlanner"/>
                        <Button fx:id="coursButton" text="Cours" styleClass="front-navbar-link" onAction="#showCours"/>
                        <Button fx:id="callLabButton" text="Call Lab" styleClass="front-navbar-link" onAction="#showCallLab"/>
                        <Button fx:id="messengerButton" text="Messagerie" styleClass="front-navbar-link" onAction="#showMessenger"/>
                        <Button fx:id="quizButton" text="Quiz" styleClass="front-navbar-link" onAction="#showQuiz"/>
                        <Button fx:id="blogButton" text="Blog" styleClass="front-navbar-link" onAction="#showBlog"/>
                    </HBox>

                    <Button text="Logout" styleClass="front-navbar-logout" onAction="#handleLogout"
                            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
                </children>
            </AnchorPane>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0" styleClass="front-workspace-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="8" right="20" bottom="20" left="20"/>
            </padding>

            <AnchorPane styleClass="front-content-surface" VBox.vgrow="ALWAYS">
                <children>
                    <AnchorPane fx:id="contentPane" styleClass="content-pane"
                                AnchorPane.bottomAnchor="0.0"
                                AnchorPane.leftAnchor="0.0"
                                AnchorPane.rightAnchor="0.0"
                                AnchorPane.topAnchor="0.0"/>
                    <Region fx:id="globalAiScrim"
                            managed="false"
                            mouseTransparent="true"
                            style="-fx-background-color: rgba(15, 23, 42, 0.16);"
                            visible="false"
                            AnchorPane.bottomAnchor="0.0"
                            AnchorPane.leftAnchor="0.0"
                            AnchorPane.rightAnchor="0.0"
                            AnchorPane.topAnchor="0.0"/>
                    <VBox fx:id="globalAiPanel"
                          managed="false"
                          maxWidth="400.0"
                          minWidth="400.0"
                          prefWidth="400.0"
                          style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.16), 18, 0, -4, 0);"
                          visible="false"
                          AnchorPane.bottomAnchor="0.0"
                          AnchorPane.rightAnchor="0.0"
                          AnchorPane.topAnchor="0.0">
                        <children>
                            <AnchorPane fx:id="globalAiContent" VBox.vgrow="ALWAYS"/>
                        </children>
                    </VBox>
                    <Button fx:id="globalAiFab"
                            onAction="#toggleGlobalAi"
                            style="-fx-background-color: linear-gradient(to bottom, #0f766e, #0d9488); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 999px; -fx-padding: 12 20;"
                            text="Ask Fahamni"
                            AnchorPane.bottomAnchor="24.0"
                            AnchorPane.rightAnchor="24.0"/>
                </children>
            </AnchorPane>
        </VBox>
    </center>
</BorderPane>
