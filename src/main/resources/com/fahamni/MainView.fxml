<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" styleClass="main-root front-navbar-shell-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.MainController">
    <top>
        <VBox spacing="12.0" styleClass="front-navbar-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18" right="20" bottom="0" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="front-navbar-topbar">
                <padding>
                    <Insets top="18" right="20" bottom="18" left="20"/>
                </padding>

                <VBox spacing="6.0" styleClass="front-navbar-brand">
                    <Label text="FAHAMNI" styleClass="front-navbar-brand-title"/>
                    <Label text="Apprendre avec clarte, progresser avec confiance." styleClass="front-navbar-brand-slogan" wrapText="true"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="14.0" alignment="CENTER_RIGHT" styleClass="front-navbar-actions">
                    <HBox spacing="10.0" alignment="CENTER" styleClass="front-navbar-utility-inline">
                        <StackPane styleClass="front-alert-button-wrap">
                            <Button fx:id="alertButton" text="🔔" styleClass="front-navbar-icon-button" onAction="#toggleAlertsPopup"/>
                            <Label fx:id="alertNotifBadge" text=""
                                   StackPane.alignment="TOP_RIGHT"
                                   managed="false" visible="false">
                                <styleClass>
                                    <String fx:value="front-badge"/>
                                    <String fx:value="front-alert-badge"/>
                                </styleClass>
                                <StackPane.margin><Insets top="-7" right="-7"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <Button fx:id="accountButton" text="Compte" styleClass="front-navbar-ghost-button" onAction="#toggleAccountMenu"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="front-navbar-profile">
                        <Label fx:id="profileAvatarLabel" text="FS" styleClass="profile-avatar"/>
                        <VBox spacing="2.0" styleClass="front-navbar-profile-copy">
                            <Label fx:id="profileNameLabel" text="Etudiant Fahamni" styleClass="profile-name"/>
                            <Label fx:id="profileRoleLabel" text="Espace Etudiant" styleClass="profile-role"/>
                        </VBox>
                    </HBox>
                </HBox>
            </HBox>

            <StackPane styleClass="front-navbar-links-row">
                <padding>
                    <Insets top="0" right="18" bottom="0" left="18"/>
                </padding>

                <HBox alignment="CENTER" spacing="18.0" styleClass="front-navbar-links-center" StackPane.alignment="CENTER">
                    <Button fx:id="dashboardButton" text="Accueil" styleClass="front-navbar-link" onAction="#showDashboard"/>
                    <Button fx:id="reservationsButton" text="Trouver un tuteur" styleClass="front-navbar-link" onAction="#showReservations"/>
                    <Button fx:id="seancesButton" text="Calendrier" styleClass="front-navbar-link" onAction="#showSeances"/>
                    <Button fx:id="sallesEquipementsButton" text="Salles &amp; Materiel" styleClass="front-navbar-link" onAction="#showSallesEquipements"/>
                    <Button fx:id="plannerButton" text="Planner" styleClass="front-navbar-link" onAction="#showPlanner"/>
                    <Button fx:id="quizButton" text="Quiz" styleClass="front-navbar-link" onAction="#showQuiz"/>

                    <Button fx:id="blogButton" text="Blog" styleClass="front-navbar-link" onAction="#showBlog"/>
                </HBox>

                <Button text="Logout" styleClass="front-navbar-logout" onAction="#handleLogout" StackPane.alignment="CENTER_RIGHT"/>
            </StackPane>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0" styleClass="front-workspace-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="8" right="20" bottom="20" left="20"/>
            </padding>

            <AnchorPane fx:id="contentPane" styleClass="content-pane front-content-surface" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
