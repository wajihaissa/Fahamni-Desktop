<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="backoffice-page"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.fahamni.controllers.BackofficeReservationsController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <VBox spacing="6.0" styleClass="backoffice-header-block">
        <Label text="Gestion des reservations" styleClass="backoffice-panel-title"/>
        <Label text="Validez rapidement les demandes et ajustez leur statut." styleClass="backoffice-panel-copy"/>
    </VBox>

    <HBox spacing="18.0">
        <VBox spacing="12.0" styleClass="backoffice-panel" HBox.hgrow="ALWAYS">
            <Label text="Demandes recues" styleClass="backoffice-section-title"/>
            <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS" styleClass="backoffice-table">
                <columns>
                    <TableColumn fx:id="studentColumn" prefWidth="170.0" text="Etudiant"/>
                    <TableColumn fx:id="sessionColumn" prefWidth="220.0" text="Seance"/>
                    <TableColumn fx:id="requestDateColumn" prefWidth="130.0" text="Date"/>
                    <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Statut"/>
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="12.0" styleClass="backoffice-panel backoffice-form-panel" prefWidth="320.0" minWidth="320.0">
            <Label text="Traitement rapide" styleClass="backoffice-section-title"/>

            <VBox spacing="6.0">
                <Label text="Etudiant" styleClass="backoffice-form-label"/>
                <TextField fx:id="studentField" promptText="Nom de l'etudiant" styleClass="backoffice-form-input"/>
            </VBox>

            <VBox spacing="6.0">
                <Label text="Seance" styleClass="backoffice-form-label"/>
                <TextField fx:id="sessionField" promptText="Titre de la seance" styleClass="backoffice-form-input"/>
            </VBox>

            <VBox spacing="6.0">
                <Label text="Date de demande" styleClass="backoffice-form-label"/>
                <TextField fx:id="requestDateField" promptText="Date" styleClass="backoffice-form-input"/>
            </VBox>

            <VBox spacing="6.0">
                <Label text="Statut" styleClass="backoffice-form-label"/>
                <ComboBox fx:id="statusComboBox" styleClass="backoffice-form-input"/>
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleConfirmReservation" text="Confirmer la reservation" styleClass="backoffice-primary-button"/>
            <Button maxWidth="Infinity" onAction="#handleCancelReservation" text="Annuler la reservation" styleClass="backoffice-secondary-button"/>
            <Button maxWidth="Infinity" onAction="#handleSaveReservation" text="Enregistrer les modifications" styleClass="backoffice-secondary-button"/>

            <Label fx:id="feedbackLabel" managed="false" visible="false" wrapText="true" styleClass="backoffice-feedback"/>
        </VBox>
    </HBox>
</VBox>

