<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane styleClass="messenger-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.Pidev3A49.controllers.MessengerController">
    <left>
        <VBox styleClass="conversations-list" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <VBox spacing="10.0" styleClass="conversations-header">
                <Label text="Messages" styleClass="conversations-title"/>
                <TextField promptText="Search conversations..." styleClass="search-field"/>
            </VBox>

            <ListView fx:id="conversationsListView" styleClass="conversations-list-view" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="10"/>
                </VBox.margin>
            </ListView>
        </VBox>
    </left>

    <center>
        <VBox styleClass="chat-area" BorderPane.alignment="CENTER">
            <VBox fx:id="chatHeader" styleClass="chat-header" spacing="5.0">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label fx:id="chatPartnerLabel" text="Select a conversation" styleClass="chat-partner"/>
                <Label fx:id="chatStatusLabel" text="" styleClass="chat-status"/>
            </VBox>

            <ScrollPane fx:id="messagesScrollPane" styleClass="messages-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="messagesContainer" styleClass="messages-container" spacing="10.0">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                </VBox>
            </ScrollPane>

            <HBox styleClass="message-input-area" spacing="10.0">
                <padding>
                    <Insets top="10" right="15" bottom="10" left="15"/>
                </padding>
                <TextField fx:id="messageTextField" promptText="Type a message..." styleClass="message-input" HBox.hgrow="ALWAYS"/>
                <Button fx:id="sendButton" text="Send" styleClass="send-button" onAction="#sendMessage"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>

