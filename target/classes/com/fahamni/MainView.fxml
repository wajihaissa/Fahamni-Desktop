<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" styleClass="main-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.fahamni.controllers.MainController">
    <left>
        <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" right="0" bottom="20" left="0"/>
            </padding>

            <VBox alignment="CENTER" spacing="10.0" styleClass="sidebar-header">
                <Label text="FAHAMNI" styleClass="sidebar-title"/>
            </VBox>

            <VBox spacing="5.0" styleClass="sidebar-menu">
                <Button fx:id="dashboardButton" maxWidth="Infinity" text="Dashboard" styleClass="sidebar-button" onAction="#showDashboard"/>
                <Button fx:id="seancesButton" maxWidth="Infinity" text="Seances" styleClass="sidebar-button" onAction="#showSeances"/>
                <Button fx:id="reservationsButton" maxWidth="Infinity" text="Reservations" styleClass="sidebar-button" onAction="#showReservations"/>
                <Button fx:id="plannerButton" maxWidth="Infinity" text="Planner" styleClass="sidebar-button" onAction="#showPlanner"/>
                <Button fx:id="messengerButton" maxWidth="Infinity" text="Messagerie" styleClass="sidebar-button" onAction="#showMessenger"/>
                <Button fx:id="quizButton" maxWidth="Infinity" text="Quiz" styleClass="sidebar-button" onAction="#showQuiz"/>
                <Button fx:id="blogButton" maxWidth="Infinity" text="Blog" styleClass="sidebar-button" onAction="#showBlog"/>
            </VBox>

            <VBox alignment="BOTTOM_CENTER" spacing="10.0" VBox.vgrow="ALWAYS" styleClass="sidebar-footer">
                <Button maxWidth="Infinity" text="Logout" styleClass="logout-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="topbar" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <VBox spacing="3.0">
                <Label fx:id="pageTitle" text="Dashboard" styleClass="page-title"/>
                <Label text="Votre espace d'apprentissage Fahamni" styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="10.0" alignment="CENTER_RIGHT" styleClass="topbar-actions">
                <Button text="Alertes" styleClass="topbar-pill-button"/>

                <StackPane pickOnBounds="false" styleClass="account-menu-wrapper">
                    <children>
                        <Button text="Compte" styleClass="topbar-pill-button" onAction="#toggleAccountMenu"/>
                        <VBox fx:id="accountMenuPane" managed="false" visible="false" spacing="6.0"
                              styleClass="account-menu-panel" translateY="48.0" StackPane.alignment="TOP_CENTER">
                            <children>
                                <Button maxWidth="Infinity" onAction="#showProfile" styleClass="account-menu-item" text="Mon profil"/>
                                <Button maxWidth="Infinity" onAction="#showSettings" styleClass="account-menu-item" text="Parametres"/>
                                <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="account-menu-item-danger" text="Deconnexion"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="topbar-profile-card">
                    <Label fx:id="profileAvatarLabel" text="FS" styleClass="profile-avatar"/>
                    <VBox spacing="2.0">
                        <Label fx:id="profileNameLabel" text="Etudiant Fahamni" styleClass="profile-name"/>
                        <Label fx:id="profileRoleLabel" text="Espace Etudiant" styleClass="profile-role"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <center>
        <AnchorPane fx:id="contentPane" styleClass="content-pane" BorderPane.alignment="CENTER"/>
    </center>
</BorderPane>
