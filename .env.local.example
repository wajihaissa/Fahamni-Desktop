# Local Gemini configuration for the desktop app.
# Copy the values you need into .env.local or fahamni.local.properties.

GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Konnect sandbox configuration
KONNECT_API_KEY=replace_with_your_konnect_sandbox_api_key
KONNECT_WALLET_ID=replace_with_your_konnect_sandbox_wallet_id
KONNECT_API_BASE_URL=https://api.sandbox.konnect.network/api/v2/
