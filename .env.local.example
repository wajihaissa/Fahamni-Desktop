# Local Gemini configuration for the desktop app.
# Copy the values you need into .env.local or fahamni.local.properties.

# Local database configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fahamni
DB_USER=root
DB_PASSWORD=
# Optional: overrides DB_HOST/DB_PORT/DB_NAME entirely
# DB_URL=jdbc:mysql://127.0.0.1:3306/fahamni?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Shared course cover compatibility with the Symfony web app
# Point this to the Symfony project's public/ directory on the same machine.
SYMFONY_PUBLIC_DIR=C:/path/to/fahamni-symfony/public
# Must match the base URL used by the local Symfony server.
APP_BASE_URL=http://127.0.0.1:8000
# Optional explicit FFmpeg/Vosk configuration for course video transcription.
FFMPEG_PATH=C:/path/to/ffmpeg/bin/ffmpeg.exe
VOSK_MODEL_FR=src/main/resources/vosk-model-fr
VOSK_MODEL_EN=src/main/resources/vosk-model-en

GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Stripe test configuration
STRIPE_SECRET_KEY=replace_with_your_stripe_test_secret_key
STRIPE_API_BASE_URL=https://api.stripe.com/
STRIPE_CURRENCY=USD
STRIPE_TND_EXCHANGE_RATE=1.0
STRIPE_MINOR_UNIT_FACTOR=100
STRIPE_LOCALE=fr
STRIPE_SUCCESS_URL=https://example.com/fahamni/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://example.com/fahamni/stripe/cancel

# SMTP receipt configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace_with_your_smtp_username
SMTP_PASSWORD=replace_with_your_smtp_password
SMTP_FROM=no-reply@fahamni.tn
SMTP_FROM_NAME=Fahamni
SMTP_STARTTLS=true
SMTP_SSL=false
